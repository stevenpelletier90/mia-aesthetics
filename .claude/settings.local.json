{
  "permissions": {
    "allow": [
      "*",
      "Bash(claude mcp:*)",
      "Bash(ls:*)",
      "Bash(find:*)",
      "mcp__sequential-thinking__sequentialthinking",
      "Bash(rm:*)",
      "WebFetch(domain:getbootstrap.com)",
      "mcp__filesystem__read_multiple_files",
      "mcp__filesystem__search_files",
      "mcp__filesystem__read_file",
      "WebFetch(domain:docs.anthropic.com)",
      "mcp__filesystem__directory_tree",
      "mcp__filesystem__edit_file",
      "mcp__filesystem__list_directory",
      "mcp__filesystem__write_file",
      "Bash(php:*)",
      "Bash(composer --version)",
      "Bash(composer run-script phpcs:*)",
      "Bash(npm run lint:*)",
      "Bash(composer run phpcs:*)",
      "Bash(grep:*)",
      "Bash(./vendor/bin/phpcs:*)",
      "Bash(./vendor/bin/phpcbf:*)",
      "Bash(--standard=WordPress --report=full)",
      "Bash(composer install:*)",
      "Bash(composer update:*)",
      "Bash(composer show:*)",
      "Bash(npm show:*)",
      "Bash(npm install)",
      "Bash(npx eslint:*)",
      "Bash(composer run:*)",
      "Bash(code:*)",
      "Bash(./vendor/bin/phpstan analyse inc/enqueue.php --level=5)",
      "Bash(./vendor/bin/phpstan analyse:*)",
      "mcp__git__git_log",
      "mcp__git__git_show",
      "mcp__git__git_diff",
      "Bash(timeout 30 ./vendor/bin/phpcs:*)"
    ],
    "deny": []
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit(file_path:**/*.css)|Write(file_path:**/*.css)",
        "hooks": [
          {
            "type": "command",
            "command": "/home/steve/projects/mia-aesthetics/.claude/check-css.sh"
          }
        ]
      },
      {
        "matcher": "Edit(file_path:**/*.php)|Write(file_path:**/*.php)",
        "hooks": [
          {
            "type": "command",
            "command": "/home/steve/projects/mia-aesthetics/.claude/check-theme.sh"
          }
        ]
      },
      {
        "matcher": "Bash(command:git commit*)",
        "hooks": [
          {
            "type": "command",
            "command": "/home/steve/projects/mia-aesthetics/.claude/check-commit.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit(file_path:**/*.php)",
        "hooks": [
          {
            "type": "command",
            "command": "php -l"
          }
        ]
      }
    ]
  }
}