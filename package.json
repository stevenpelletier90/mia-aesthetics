{
  "name": "mia-aesthetics-theme",
  "version": "3.0.0",
  "description": "Mia Aesthetics WordPress Theme",
  "type": "module",
  "private": true,
  "scripts": {
    "sass:build": "sass assets/scss/main.scss:assets/css/theme.css --style=expanded --source-map",
    "sass:build:individual": "sass assets/scss/base/_fonts.scss:assets/css/fonts.css assets/scss/layout/_hero-section.scss:assets/css/layout/hero-section.css assets/scss/components/_case-card.scss:assets/css/components/case-card.css assets/scss/components/_careers-cta.scss:assets/css/components/careers-cta.css assets/scss/components/_consultation-form.scss:assets/css/components/consultation-form.css --style=expanded --source-map",
    "sass:build:templates": "sass assets/scss/templates/pages/front-page.scss:assets/css/templates/pages/front-page.css assets/scss/templates/pages/page-before-after-by-doctor.scss:assets/css/templates/pages/page-before-after-by-doctor.css assets/scss/templates/pages/page-blank-canvas.scss:assets/css/templates/pages/page-blank-canvas.css assets/scss/templates/pages/page-careers.scss:assets/css/templates/pages/page-careers.css assets/scss/templates/pages/page-case-category.scss:assets/css/templates/pages/page-case-category.css assets/scss/templates/pages/page-condition-layout.scss:assets/css/templates/pages/page-condition-layout.css assets/scss/templates/pages/page-hero-canvas.scss:assets/css/templates/pages/page-hero-canvas.css assets/scss/templates/pages/page-no-bc.scss:assets/css/templates/pages/page-no-bc.css assets/scss/templates/pages/page-procedures-listing.scss:assets/css/templates/pages/page-procedures-listing.css assets/scss/templates/pages/page-procedures-manual.scss:assets/css/templates/pages/page-procedures-manual.css assets/scss/templates/pages/page-treatment-layout.scss:assets/css/templates/pages/page-treatment-layout.css assets/scss/templates/pages/page.scss:assets/css/templates/pages/page.css assets/scss/templates/archives/archive-case.scss:assets/css/templates/archives/archive-case.css assets/scss/templates/archives/archive-condition.scss:assets/css/templates/archives/archive-condition.css assets/scss/templates/archives/archive-location.scss:assets/css/templates/archives/archive-location.css assets/scss/templates/archives/archive-non-surgical.scss:assets/css/templates/archives/archive-non-surgical.css assets/scss/templates/archives/archive-procedure.scss:assets/css/templates/archives/archive-procedure.css assets/scss/templates/archives/archive-special.scss:assets/css/templates/archives/archive-special.css assets/scss/templates/archives/archive-surgeon.scss:assets/css/templates/archives/archive-surgeon.css assets/scss/templates/archives/archive.scss:assets/css/templates/archives/archive.css assets/scss/templates/singles/single-case.scss:assets/css/templates/singles/single-case.css assets/scss/templates/singles/single-location.scss:assets/css/templates/singles/single-location.css assets/scss/templates/singles/single-post.scss:assets/css/templates/singles/single-post.css assets/scss/templates/singles/single-special.scss:assets/css/templates/singles/single-special.css assets/scss/templates/singles/single-surgeon.scss:assets/css/templates/singles/single-surgeon.css assets/scss/templates/misc/404.scss:assets/css/templates/misc/404.css assets/scss/templates/misc/case-category.scss:assets/css/templates/misc/case-category.css assets/scss/templates/misc/category.scss:assets/css/templates/misc/category.css assets/scss/templates/misc/home.scss:assets/css/templates/misc/home.css assets/scss/templates/misc/index.scss:assets/css/templates/misc/index.css assets/scss/templates/misc/search.scss:assets/css/templates/misc/search.css assets/scss/utilities/careers-locations.scss:assets/css/utilities/careers-locations.css assets/scss/utilities/location-search-careers.scss:assets/css/utilities/location-search-careers.css assets/scss/utilities/location-search.scss:assets/css/utilities/location-search.css --style=expanded --source-map",
    "postcss:theme": "postcss assets/css/theme.css -o assets/css/theme.min.css",
    "build:theme": "npm run sass:build && npm run postcss:theme",
    "lint": "npm run lint:js && npm run lint:php",
    "lint:js": "eslint assets/js/**/*.js --ignore-pattern '**/*.min.js' --no-warn-ignored",
    "lint:scss": "stylelint \"assets/scss/**/*.scss\"",
    "lint:scss:fix": "stylelint \"assets/scss/**/*.scss\" --fix",
    "lint:scss:prettier": "prettier --check \"assets/scss/**/*.scss\"",
    "lint:php": "composer run-script phpcs && composer run-script phpstan",
    "qa:fe": "npm run lint:js && npm run lint:scss && npm run lint:scss:prettier && npm run format:check",
    "lint:fix": "npm run lint:js:fix && npm run format:scss",
    "lint:js:fix": "eslint assets/js/**/*.js --fix --ignore-pattern '**/*.min.js' --no-warn-ignored",
    "format": "prettier --write \"assets/**/*.{css,js,scss}\"",
    "format:scss": "prettier --write \"assets/scss/**/*.scss\"",
    "format:js": "prettier --write \"assets/js/**/*.js\"",
    "format:check": "prettier --check \"assets/**/*.{css,js,scss}\"",
    "qa:all": "npm run qa:fe && composer qa",
    "minify:css": "node scripts/minify-assets.js css",
    "minify:js": "node scripts/minify-assets.js js",
    "minify:all": "node scripts/minify-assets.js all",
    "build:assets": "npm run sass:build && npm run sass:build:individual && npm run sass:build:templates && npm run postcss:theme && npm run minify:all",
    "build:production": "npm run lint && npm run format && npm run build:assets && npm run bundle",
    "bundle": "node scripts/bundle-theme.js",
    "bundle:clean": "npm run lint && npm run format && npm run bundle",
    "dev:clean": "npm run sass:build && npm run sass:build:individual && npm run sass:build:templates && npm run bundle",
    "setup:assets": "node scripts/bundle-theme.js --dev-copy",
    "setup": "npm run setup:assets"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.21",
    "cssnano": "^7.1.1",
    "cssnano-preset-default": "^7.0.9",
    "eslint": "^9.34.0",
    "eslint-config-prettier": "^10.1.8",
    "postcss": "^8.5.6",
    "postcss-cli": "^11.0.1",
    "prettier": "^3.6.2",
    "sass": "^1.92.0",
    "stylelint": "^16.23.1",
    "stylelint-config-standard-scss": "^15.0.1",
    "terser": "^5.44.0"
  },
  "dependencies": {
    "@fortawesome/fontawesome-free": "^7.0.1",
    "@glidejs/glide": "^3.7.1",
    "bootstrap": "^5.3.8"
  }
}
