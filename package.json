{
  "name": "mia-aesthetics-theme",
  "version": "3.0.0",
  "description": "Mia Aesthetics WordPress Theme",
  "type": "module",
  "private": true,
  "scripts": {
    "sass:compile": "sass assets/scss/main.scss:assets/css/theme.css --style=expanded",
    "sass:watch": "sass --watch assets/scss:assets/css --style=expanded",
    "sass:build": "sass assets/scss/main.scss:assets/css/theme.css --style=expanded --source-map && sed -i '' 's/-webkit-appearance: *\\([^;]*\\);/-webkit-appearance: \\1; appearance: \\1;/g' assets/css/theme.css",
    "sass:build:compressed": "sass assets/scss/main.scss:assets/css/theme.compressed.css --style=compressed --source-map",
    "postcss:prefixes": "postcss assets/css/theme.css -o assets/css/theme.prefixed.css && sed -i '' 's/-webkit-appearance: *\\([^;]*\\);/-webkit-appearance: \\1; appearance: \\1;/g' assets/css/theme.prefixed.css",
    "postcss:minify": "postcss assets/css/theme.prefixed.css -o assets/css/theme.min.css --use cssnano",
    "build:theme": "npm run sass:build && npm run postcss:prefixes && npm run postcss:minify",
    "dev:theme": "npm run sass:compile",
    "watch:theme": "npm run sass:watch",
    "lint": "npm run lint:js && npm run lint:css && npm run lint:php",
    "lint:js": "eslint assets/js/**/*.js --ignore-pattern '**/*.min.js' --no-warn-ignored",
    "lint:css": "prettier --check \"assets/css/**/*.css\" --ignore-path .minignore",
    "lint:scss": "prettier --check \"assets/scss/**/*.scss\"",
    "lint:php": "composer run-script phpcs && composer run-script phpstan",
    "qa:fe": "npm run lint:js && npm run lint:css && npm run lint:scss && npm run format:check",
    "lint:fix": "npm run lint:js:fix && npm run format:css && npm run format:scss",
    "lint:js:fix": "eslint assets/js/**/*.js --fix --ignore-pattern '**/*.min.js' --no-warn-ignored",
    "format": "prettier --write \"assets/**/*.{css,js,scss}\" --ignore-path .minignore",
    "format:css": "prettier --write \"assets/css/**/*.css\" --ignore-path .minignore",
    "format:scss": "prettier --write \"assets/scss/**/*.scss\"",
    "format:js": "prettier --write \"assets/js/**/*.js\" --ignore-path .minignore",
    "format:check": "prettier --check \"assets/**/*.{css,js,scss}\" --ignore-path .minignore",
    "qa:all": "npm run qa:fe && composer qa",
    "minify:css": "node scripts/minify-assets.js css",
    "minify:js": "node scripts/minify-assets.js js",
    "minify:all": "node scripts/minify-assets.js all",
    "build:assets": "npm run build:theme && npm run minify:all",
    "build:production": "npm run lint && npm run format && npm run build:assets && npm run bundle",
    "bundle": "node scripts/bundle-theme.js",
    "bundle:clean": "npm run lint && npm run format && npm run bundle",
    "setup:assets": "node scripts/bundle-theme.js --dev-copy",
    "setup": "npm run setup:assets"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.21",
    "cssnano": "^7.1.1",
    "cssnano-preset-default": "^7.0.9",
    "eslint": "^9.34.0",
    "eslint-config-prettier": "^10.1.8",
    "postcss": "^8.5.6",
    "postcss-cli": "^11.0.1",
    "postcss-import": "^16.1.1",
    "prettier": "^3.6.2",
    "sass": "^1.91.0",
    "terser": "^5.43.1"
  },
  "dependencies": {
    "@fortawesome/fontawesome-free": "^7.0.0",
    "@glidejs/glide": "^3.7.1",
    "bootstrap": "^5.3.8"
  }
}
