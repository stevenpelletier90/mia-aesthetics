{
  "name": "mia-aesthetics-theme",
  "version": "3.0.0",
  "description": "Mia Aesthetics WordPress Theme",
  "private": true,
  "scripts": {
    "lint": "npm run lint:js && npm run lint:css && npm run lint:php",
    "lint:js": "eslint assets/js/**/*.js",
    "lint:css": "stylelint assets/css/**/*.css",
    "lint:php": "composer run-script phpcs",
    "lint:fix": "npm run lint:js:fix && npm run lint:css:fix && npm run format",
    "lint:js:fix": "eslint assets/js/**/*.js --fix",
    "lint:css:fix": "stylelint assets/css/**/*.css --fix",
    "format": "prettier --write '**/*.{js,css,json,md}'",
    "format:check": "prettier --check '**/*.{js,css,json,md}'"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-config-wordpress": "^2.0.0",
    "prettier": "^3.2.5",
    "stylelint": "^16.2.1",
    "stylelint-prettier": "^5.0.0",
    "stylelint-config-standard": "^36.0.0"
  }
}
