<?xml version="1.0"?>
<ruleset name="Mia Aesthetics WordPress Theme">
	<description>WordPress Coding Standards for Mia Aesthetics Theme</description>

	<!-- Scan these files -->
	<file>.</file>

	<!-- Exclude paths -->
	<exclude-pattern>*/node_modules/*</exclude-pattern>
	<exclude-pattern>*/vendor/*</exclude-pattern>
	<exclude-pattern>*/assets/bootstrap/*</exclude-pattern>
	<exclude-pattern>*/assets/fontawesome/*</exclude-pattern>
	<exclude-pattern>*/assets/js/*</exclude-pattern>
	<exclude-pattern>*/assets/css/*</exclude-pattern>
	<exclude-pattern>*/assets/fonts/*</exclude-pattern>
	<exclude-pattern>*/assets/data/*</exclude-pattern>
	<exclude-pattern>*.min.js</exclude-pattern>
	<exclude-pattern>*.min.css</exclude-pattern>
	<exclude-pattern>*.js</exclude-pattern>
	<exclude-pattern>*.css</exclude-pattern>

	<!-- Check up to 8 files simultaneously -->
	<arg name="parallel" value="8"/>

	<!-- Show colors in console -->
	<arg name="colors"/>

	<!-- Show sniff codes in all reports -->
	<arg value="ps"/>

	<!-- Use WordPress-Extra as the base -->
	<rule ref="WordPress-Extra">
		<!-- Allow short array syntax -->
		<exclude name="Generic.Arrays.DisallowShortArraySyntax.Found"/>
		
		<!-- Allow Yoda conditions to be optional -->
		<exclude name="WordPress.PHP.YodaConditions.NotYoda"/>
		
		<!-- We'll handle file comments differently -->
		<exclude name="Squiz.Commenting.FileComment.Missing"/>
		<exclude name="Squiz.Commenting.FileComment.MissingPackageTag"/>
	</rule>

	<!-- Include WordPress-Docs for inline documentation -->
	<rule ref="WordPress-Docs">
		<!-- Don't require documentation for every hook -->
		<exclude name="WordPress.NamingConventions.PrefixAllGlobals.NonPrefixedHooknameFound"/>
	</rule>

	<!-- Verify PHP compatibility with PHP 7.4+ -->
	<config name="testVersion" value="7.4-"/>
	<rule ref="PHPCompatibilityWP"/>

	<!-- WordPress naming conventions -->
	<rule ref="WordPress.NamingConventions.PrefixAllGlobals">
		<properties>
			<property name="prefixes" type="array">
				<element value="mia_aesthetics"/>
				<element value="Mia_Aesthetics"/>
			</property>
		</properties>
	</rule>

	<!-- Set minimum supported WP version -->
	<config name="minimum_supported_wp_version" value="5.9"/>

	<!-- Allow theme-specific global variables -->
	<rule ref="WordPress.NamingConventions.PrefixAllGlobals.NonPrefixedVariableFound">
		<exclude-pattern>functions.php</exclude-pattern>
	</rule>

	<!-- Text domain for i18n -->
	<rule ref="WordPress.WP.I18n">
		<properties>
			<property name="text_domain" type="array">
				<element value="mia-aesthetics"/>
			</property>
		</properties>
	</rule>

	<!-- Disallow PHP short tags -->
	<rule ref="Generic.PHP.DisallowShortOpenTag"/>
	<rule ref="Generic.PHP.DisallowAlternativePHPTags"/>

	<!-- Force array indentation -->
	<rule ref="Generic.Arrays.ArrayIndent"/>

	<!-- Ensure proper spacing around operators -->
	<rule ref="Squiz.WhiteSpace.OperatorSpacing">
		<properties>
			<property name="ignoreNewlines" value="true"/>
		</properties>
	</rule>

	<!-- Line length limits - disabled -->
	<rule ref="Generic.Files.LineLength">
		<severity>0</severity>
	</rule>
</ruleset>