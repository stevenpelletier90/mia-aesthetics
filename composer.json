{
  "require-dev": {
    "squizlabs/php_codesniffer": "^3.10",
    "phpstan/phpstan": "^2.1",
    "wp-coding-standards/wpcs": "^3.1",
    "dealerdirect/phpcodesniffer-composer-installer": "^1.0",
    "php-stubs/wordpress-stubs": "^6.6",
    "php-stubs/acf-pro-stubs": "^6.3",
    "php-stubs/gravity-forms-stubs": "^2.8",
    "php-stubs/wordpress-seo-stubs": "^20.5",
    "szepeviktor/phpstan-wordpress": "^2.0",
    "php-stubs/wp-cli-stubs": "^2.10",
    "phpstan/phpstan-strict-rules": "^2.0",
    "phpstan/extension-installer": "^1.4",
    "rector/rector": "^2.1",
    "nunomaduro/phpinsights": "^2.13"
  },
  "config": {
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true,
      "phpstan/extension-installer": true
    }
  },
  "scripts": {
    "phpcs": "phpcs",
    "phpcbf": "phpcbf",
    "phpstan": "phpstan analyse --memory-limit=2G --no-progress",
    "insights": "php -d memory_limit=1G ./vendor/bin/phpinsights analyse -n --summary",
    "qa": "composer phpcbf && composer phpcs && composer phpstan && composer insights"
  }
}
