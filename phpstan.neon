parameters:
    level: 5
    paths:
        - .
    excludePaths:
        - vendor/
        - node_modules/
        - assets/bootstrap/
        - assets/fontawesome/
        - '.claude/'
    bootstrapFiles:
        - vendor/php-stubs/wordpress-stubs/wordpress-stubs.php
        - vendor/php-stubs/acf-pro-stubs/acf-pro-stubs.php
        - vendor/php-stubs/gravity-forms-stubs/gravity-forms-stubs.php
        - vendor/php-stubs/wordpress-seo-stubs/wordpress-seo-stubs.php
        # Removed to reduce memory usage:
        # - vendor/php-stubs/wp-cli-stubs/wp-cli-stubs.php
        # - vendor/php-stubs/genesis-stubs/genesis-stubs.php
    
    # Memory and performance
    # tmpDir: '.phpstan-cache'  # Commented out to use system temp directory
    reportUnmatchedIgnoredErrors: false
    
    # Disable parallel processing completely
    parallel:
        maximumNumberOfProcesses: 1
        processTimeout: 300.0